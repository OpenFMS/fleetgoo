---
import { getCollection } from 'astro:content';
import fs from 'fs';
import path from 'path';
import Layout from '../../../layouts/Layout.astro';
import { CalendarIcon, UserIcon, ArrowRightIcon } from 'lucide-react';

export async function getStaticPaths() {
  const dataDir = path.resolve(process.cwd(), 'public/data');
  if (!fs.existsSync(dataDir)) return [];
  const items = fs.readdirSync(dataDir, { withFileTypes: true });
  const languages = items.filter(item => item.isDirectory() && item.name !== 'admin').map(item => item.name);
  
  return languages.map(lang => {
    return {
      params: { lang },
      props: { lang }
    };
  });
}

const { lang } = Astro.props;

// Fetch ALL blog posts for the current language
const allPosts = await getCollection('blog', ({ id, slug }) => {
  return id.startsWith(`${lang}/`) || slug.startsWith(`${lang}/`);
});

// Sort by date descending
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Read global layout props
const readJson = (filePath) => {
  try {
    const fullPath = path.resolve(process.cwd(), 'public', filePath);
    if (fs.existsSync(fullPath)) return JSON.parse(fs.readFileSync(fullPath, 'utf-8'));
  } catch (e) {}
  return null;
};
const settings = readJson('data/settings.json') || {};
const commonData = readJson(`data/${lang}/common.json`) || {};

const pageTitle = lang === 'zh' ? '博客与资源' : 'Blog & Resources';
const pageSubtitle = lang === 'zh' ? '行业洞察与第一手资讯' : 'Industry Insights and Latest News';
---

<Layout title={`${pageTitle} | FleetGoo`} language={lang} settings={settings} commonData={commonData}>
  <div class="bg-blue-600 dark:bg-blue-900 pt-32 pb-20 text-center">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 uppercase tracking-wider">{pageTitle}</h1>
      <p class="text-xl text-blue-100 max-w-2xl mx-auto">{pageSubtitle}</p>
    </div>
  </div>

  <section class="py-20 bg-slate-50 dark:bg-slate-900 min-h-[50vh]">
    <div class="container mx-auto px-4 max-w-7xl">
      {allPosts.length === 0 ? (
        <div class="text-center text-slate-500 my-20">
          <p class="text-xl">No posts available for this language.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {allPosts.map(post => {
            const [_, ...slugParts] = post.slug.split('/');
            const postSlug = slugParts.join('/');
            const postUrl = `/${lang}/blog/${postSlug}`;
            
            return (
              <a href={postUrl} class="group bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-700 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col">
                <div class="aspect-video w-full bg-slate-200 dark:bg-slate-700 overflow-hidden relative">
                  {post.data.image ? (
                    <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-slate-400">FleetGoo Blog</div>
                  )}
                  {post.data.tags && post.data.tags[0] && (
                    <div class="absolute top-4 left-4 bg-blue-600 text-white text-xs px-3 py-1 rounded-full uppercase tracking-wider font-semibold">
                      {post.data.tags[0]}
                    </div>
                  )}
                </div>
                
                <div class="p-6 flex-grow flex flex-col">
                  <div class="flex items-center gap-4 text-xs text-slate-500 dark:text-slate-400 mb-4">
                    <div class="flex items-center gap-1.5">
                      <CalendarIcon className="w-4 h-4" />
                      <time datetime={post.data.pubDate.toISOString()}>
                        {post.data.pubDate.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', {
                          year: 'numeric', month: 'short', day: 'numeric'
                        })}
                      </time>
                    </div>
                    {post.data.author && (
                      <div class="flex items-center gap-1.5">
                        <UserIcon className="w-4 h-4" />
                        <span>{post.data.author}</span>
                      </div>
                    )}
                  </div>
                  
                  <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-3 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors line-clamp-2">
                    {post.data.title}
                  </h2>
                  
                  <p class="text-slate-600 dark:text-slate-300 text-sm line-clamp-3 mb-6">
                    {post.data.description}
                  </p>
                  
                  <div class="mt-auto flex items-center gap-2 text-sm font-semibold text-blue-600 dark:text-blue-400 group-hover:gap-3 transition-all">
                    {lang === 'zh' ? '阅读全文' : 'Read More'}
                    <ArrowRightIcon className="w-4 h-4" />
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </section>
</Layout>
