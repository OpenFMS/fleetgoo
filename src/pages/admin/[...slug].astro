---
import '@/index.css';
import AdminEntry from '../../components/admin/AdminEntry.jsx';

export function getStaticPaths() {
	// SECURITY: Entirely exclude admin routes from the production build.
	// This ensures that /admin directory doesn't even exist in the 'dist' folder.
	if (import.meta.env.PROD) {
		return [];
	}

	return [
		{ params: { slug: undefined } }, // Matches /admin
		{ params: { slug: 'editor' } },  // Matches /admin/editor
		{ params: { slug: 'languages' } } // Matches /admin/languages
	];
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>FleetGoo Admin Backend</title>
  </head>
  <body class="bg-slate-50 dark:bg-slate-950 font-sans antialiased text-slate-900">
    <AdminEntry client:only="react" />
  </body>
</html>
