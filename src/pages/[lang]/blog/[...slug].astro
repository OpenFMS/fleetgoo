---
import { getCollection } from 'astro:content';
import fs from 'fs';
import path from 'path';
import Layout from '../../../layouts/Layout.astro';
import { CalendarIcon, UserIcon, ArrowLeftIcon, TagIcon } from 'lucide-react';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  return allPosts.map(post => {
    // the post.slug in collections includes the folder structure, e.g. "en/future-of-fleet-management"
    const [lang, ...slugParts] = post.slug.split('/');
    const cleanSlug = slugParts.join('/'); 
    
    return {
      params: { lang, slug: cleanSlug },
      props: { post, lang }
    };
  });
}

const { post, lang } = Astro.props;
const { Content } = await post.render();

// Read global layout props
const readJson = (filePath) => {
  try {
    const fullPath = path.resolve(process.cwd(), 'public', filePath);
    if (fs.existsSync(fullPath)) return JSON.parse(fs.readFileSync(fullPath, 'utf-8'));
  } catch (e) {}
  return null;
};
const settings = readJson('data/settings.json') || {};
const commonData = readJson(`data/${lang}/common.json`) || {};

const backText = lang === 'zh' ? '返回博客列表' : 'Back to Blog';
---

<Layout title={`${post.data.title} | FleetGoo Blog`} language={lang} settings={settings} commonData={commonData}>
  
  <article class="pt-32 pb-20 bg-slate-50 dark:bg-slate-950 min-h-screen relative">
    {/* Decorative background shape */}
    <div class="absolute inset-0 z-0 bg-blue-600/5 dark:bg-blue-900/10 h-[50vh] -skew-y-3 transform-gpu origin-top-left overflow-hidden pointer-events-none"></div>
    
    <div class="container mx-auto px-4 max-w-4xl relative z-10">
      
      {/* Back button */}
      <a href={`/${lang}/blog`} class="inline-flex items-center gap-2 text-blue-600 dark:text-blue-400 hover:text-blue-700 font-semibold mb-8 transition-colors">
        <ArrowLeftIcon className="w-4 h-4" />
        {backText}
      </a>
      
      {/* Headers */}
      <header class="mb-12">
        <h1 class="text-3xl md:text-5xl font-bold text-slate-900 dark:text-white mb-6 leading-tight">
          {post.data.title}
        </h1>
        
        <p class="text-lg md:text-xl text-slate-600 dark:text-slate-300 mb-8 border-l-4 border-blue-500 pl-4 py-1 italic">
          {post.data.description}
        </p>

        <div class="flex flex-wrap items-center gap-6 text-sm text-slate-500 dark:text-slate-400 border-t border-b border-slate-200 dark:border-slate-800 py-4">
          <div class="flex items-center gap-2">
            <UserIcon className="w-4 h-4 text-blue-500" />
            <span class="font-medium text-slate-700 dark:text-slate-300">{post.data.author}</span>
          </div>
          <div class="flex items-center gap-2">
            <CalendarIcon className="w-4 h-4 text-slate-400" />
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', {
                year: 'numeric', month: 'long', day: 'numeric'
              })}
            </time>
          </div>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="flex items-center gap-2">
              <TagIcon className="w-4 h-4 text-slate-400" />
              <div class="flex gap-2">
                {post.data.tags.map(tag => (
                  <span class="bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 px-2 py-0.5 rounded-md text-xs font-semibold uppercase tracking-wide">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          )}
        </div>
      </header>

      {/* Featured Image */}
      {post.data.image && (
        <div class="mb-12 rounded-3xl overflow-hidden shadow-2xl relative bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 p-2">
          <img src={post.data.image} alt={post.data.title} class="w-full h-auto max-h-[60vh] object-cover rounded-2xl" />
        </div>
      )}

      {/* Content Body */}
      <div class="prose prose-lg prose-slate dark:prose-invert max-w-none prose-headings:font-bold prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-img:rounded-xl">
        <Content />
      </div>
      
    </div>
  </article>
</Layout>
