---
// Redirect old /about to /about-us
import fs from 'fs';
import path from 'path';

let defaultLang = 'en';
try {
  const settingsPath = path.resolve(process.cwd(), 'public/data/settings.json');
  if (fs.existsSync(settingsPath)) {
    const settings = JSON.parse(fs.readFileSync(settingsPath, 'utf8'));
    defaultLang = settings.defaultLanguage || 'en';
  }
} catch (e) {}

return Astro.redirect(`/${defaultLang}/about-us`);
---
