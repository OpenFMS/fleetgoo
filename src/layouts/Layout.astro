---
import '@/index.css';
import Header from '@/components/Header';
import Footer from '@/components/Footer';
import { Toaster } from '@/components/ui/toaster';

const { title, language = 'en', settings = {}, commonData = {} } = Astro.props;
---

<!doctype html>
<html lang={language} class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/x-icon" href={settings.branding?.favicon || "/images/favicons/favicon.ico"} />
		<link rel="icon" type="image/png" sizes="32x32" href="/images/favicons/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/images/favicons/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/images/favicons/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

        {/* Organization Schema (JSON-LD) */}
        <script type="application/ld+json" set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "Organization",
          "name": settings.seo?.siteName || "FleetGoo",
          "url": settings.seo?.siteUrl || "https://www.fleetgoo.com",
          "logo": `${settings.seo?.siteUrl || 'https://www.fleetgoo.com'}${settings.branding?.logoLight || '/images/brand/logo-light.webp'}`,
          "description": settings.seo?.defaultDescription || "Leading provider of AI-powered fleet management solutions, 4G AI dashcams, MDVR, GPS tracking, and fleet management software for commercial vehicles.",
          "telephone": settings.organization?.phone || "+86 150-138-15400",
          "email": settings.organization?.email || "sales@fleetgoo.com",
          "sameAs": settings.socialLinks?.map(link => link.url) || [],
          "foundingDate": "2010"
        })} />

        {/* WebSite Schema (JSON-LD) */}
        <script type="application/ld+json" set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "WebSite",
          "name": settings.seo?.siteName || "FleetGoo",
          "url": settings.seo?.siteUrl || "https://www.fleetgoo.com",
          "inLanguage": language,
          "potentialAction": {
            "@type": "SearchAction",
            "target": `${settings.seo?.siteUrl || 'https://www.fleetgoo.com'}/?s={search_term_string}`,
            "query-input": "required name=search_term_string"
          }
        })} />

        <script is:inline>
            // React ThemeProvider sync (prevent FOUC)
            const getThemePreference = () => {
                if (typeof localStorage !== 'undefined' && localStorage.getItem('vite-ui-theme')) {
                    return localStorage.getItem('vite-ui-theme');
                }
                return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            };
            const isDark = getThemePreference() === 'dark' || (getThemePreference() === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
            if (isDark) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        </script>
	</head>
	<body class="min-h-screen bg-slate-50 dark:bg-slate-950 flex flex-col transition-colors duration-300 font-sans antialiased">
		
        {/* Top site header */}
        <Header client:load language={language} commonData={commonData} settings={settings} />

        {/* Main page content injected from slot */}
		<main class="flex-grow pt-20">
		    <slot />
        </main>

        {/* Bottom site footer */}
        <Footer client:visible language={language} commonData={commonData} settings={settings} />
        
        {/* Global Toast notifications */}
        <Toaster client:load />

	</body>
</html>
